# ─────────────────────────────────────────────────────────────────────────────
#  AWS 연동 모드 환경변수 — 실제 값으로 채운 뒤 .env.aws 로 복사
#  절대 Git 커밋 금지 (.gitignore에 .env.aws 추가 필요)
#
#  ECS 배포 시에는 이 파일 대신 Terraform의 ECS Task Definition에서 관리
# ─────────────────────────────────────────────────────────────────────────────

APP_MODE=aws
PORT=3000

# ── RDS MySQL ──────────────────────────────────────────────────────────────────
DB_HOST=<your-rds-endpoint>.ap-northeast-2.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=<your-rds-password>
DB_NAME=travel_booking

# ── Cognito ────────────────────────────────────────────────────────────────────
COGNITO_USER_POOL_ID=ap-northeast-2_XXXXXXXXX
COGNITO_CLIENT_ID=<your-app-client-id>

# ── DynamoDB (AWS) ─────────────────────────────────────────────────────────────
# DYNAMO_ENDPOINT 는 비워둠 → AWS DynamoDB 자동 사용
DYNAMO_TABLE=TravelBookingCache
AWS_REGION=ap-northeast-2

# ── AWS 자격증명 ────────────────────────────────────────────────────────────────
# EC2/ECS에서는 IAM Role로 자동 처리 → 아래 두 줄 불필요
# 로컬에서 실제 AWS 연결 테스트 시에만 사용
# AWS_ACCESS_KEY_ID=<your-access-key>
# AWS_SECRET_ACCESS_KEY=<your-secret-key>

# ── S3 영상 스트리밍 (MediaConvert) ─────────────────────────────────────────────
# source: 원본 MP4 업로드 버킷
S3_SOURCE_BUCKET=your-source-videos-bucket
# output: HLS 변환본 저장 버킷
S3_OUTPUT_BUCKET=your-output-videos-bucket
# CloudFront 도메인 (output 버킷 앞단)
S3_CLOUDFRONT_DOMAIN=https://xxxx.cloudfront.net
# Lambda ↔ Backend 공유 시크릿 (MediaConvert 완료 콜백 인증)
LAMBDA_CALLBACK_SECRET=<랜덤-시크릿-문자열>

# ── MediaConvert ─────────────────────────────────────────────────────────────────
# 리전별 엔드포인트: AWS 콘솔 → MediaConvert → 엔드포인트에서 확인
MEDIACONVERT_ENDPOINT=https://xxxx.mediaconvert.ap-northeast-2.amazonaws.com
# MediaConvert 실행에 필요한 IAM 역할 ARN
MEDIACONVERT_ROLE_ARN=arn:aws:iam::<account-id>:role/MediaConvertRole

# ── CORS ────────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://<your-frontend-ec2-ip>
