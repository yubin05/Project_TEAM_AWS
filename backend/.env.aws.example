# ─────────────────────────────────────────────────────────────────────────────
#  AWS 연동 모드 환경변수 — 실제 값으로 채운 뒤 .env.aws 로 복사
#  절대 Git 커밋 금지 (.gitignore에 .env.aws 추가 필요)
#
#  ECS 배포 시에는 이 파일 대신 Terraform의 ECS Task Definition에서 관리
# ─────────────────────────────────────────────────────────────────────────────

APP_MODE=aws
PORT=3000

# ── RDS MySQL ──────────────────────────────────────────────────────────────────
DB_HOST=<your-rds-endpoint>.ap-northeast-2.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=<your-rds-password>
DB_NAME=travel_booking

# ── Cognito ────────────────────────────────────────────────────────────────────
COGNITO_USER_POOL_ID=ap-northeast-2_XXXXXXXXX
COGNITO_CLIENT_ID=<your-app-client-id>

# ── DynamoDB (AWS) ─────────────────────────────────────────────────────────────
# DYNAMO_ENDPOINT 는 비워둠 → AWS DynamoDB 자동 사용
DYNAMO_TABLE=TravelBookingCache
AWS_REGION=ap-northeast-2

# ── AWS 자격증명 ────────────────────────────────────────────────────────────────
# EC2/ECS에서는 IAM Role로 자동 처리 → 아래 두 줄 불필요
# 로컬에서 실제 AWS 연결 테스트 시에만 사용
# AWS_ACCESS_KEY_ID=<your-access-key>
# AWS_SECRET_ACCESS_KEY=<your-secret-key>

# ── CORS ────────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://<your-frontend-ec2-ip>
