{
  "name": "travel-booking-backend",
  "version": "1.0.0",
  "description": "야놀자 스타일 여행 및 숙박 예약 앱 백엔드",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev":   "ts-node-dev --respawn --transpile-only src/app.ts",
    "seed":  "node dist/seed.js"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb":  "^3.600.0",
    "@aws-sdk/client-translate": "^3.600.0",
    "@aws-sdk/lib-dynamodb":     "^3.600.0",
    "aws-jwt-verify":            "^4.0.1",
    "bcryptjs":                  "^2.4.3",
    "cors":                      "^2.8.5",
    "express":                   "^4.18.2",
    "jsonwebtoken":               "^9.0.2",
    "multer":                    "^1.4.5-lts.1",
    "mysql2":                    "^3.9.7",
    "uuid":                      "^9.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs":    "^2.4.6",
    "@types/cors":        "^2.8.17",
    "@types/express":     "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer":      "^1.4.11",
    "@types/node":        "^20.11.5",
    "@types/uuid":        "^9.0.7",
    "ts-node-dev":        "^2.0.0",
    "typescript":         "^5.3.3"
  }
}
