{
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/app/auth/app.log",
            "log_group_name": "/travel-app/auth-service",
            "log_stream_name": "{instance_id}",
            "timestamp_format": "%Y-%m-%dT%H:%M:%S",
            "multi_line_start_pattern": "\\{\"timestamp\""
          },
          {
            "file_path": "/var/log/app/auth/error.log",
            "log_group_name": "/travel-app/auth-service/errors",
            "log_stream_name": "{instance_id}",
            "timestamp_format": "%Y-%m-%dT%H:%M:%S",
            "multi_line_start_pattern": "\\{\"timestamp\""
          },
          {
            "file_path": "/var/log/app/hotel/app.log",
