# 기본: 텍스트 파일 자동 정규화
* text=auto

# 항상 LF로 강제 (Linux에서 실행되는 파일)
*.sh    text eol=lf
*.sql   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.tf    text eol=lf
*.tfvars text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.ts    text eol=lf
*.js    text eol=lf
*.css   text eol=lf
*.html  text eol=lf

# 바이너리 파일
*.png   binary
*.jpg   binary
*.jpeg  binary
*.pdf   binary
*.zip   binary
