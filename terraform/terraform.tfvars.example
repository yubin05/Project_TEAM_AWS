# ── 사용법 ────────────────────────────────────────────────────────────────────
#
# 이 파일을 복사해서 terraform.tfvars 를 만드세요.
#   cp terraform.tfvars.example terraform.tfvars
#
# terraform.tfvars 는 .gitignore 처리됨 (절대 커밋 금지)
# 계정 전환 시 aws_profile / deploy_branch 만 바꾸고 terraform apply 실행

aws_profile   = "my-aws-cli-profile"   # aws configure --profile 으로 등록한 이름
deploy_branch = "dev"                  # 개인: "dev" / 팀: "main"

github_owner           = "github-username"
github_repo_name       = "Project_TEAM_AWS"
github_connection_uuid = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"  # CodePipeline → Settings → Connections
github_token           = "ghp_xxxxxxxxxxxxxxxxxxxx"              # GitHub PAT (repo 권한)

key_name        = "my-ec2-keypair"
db_password     = "Change-me-password1!"
jwt_secret      = "change-me-jwt-secret-32chars!!"
internal_secret = "change-me-internal-secret"
