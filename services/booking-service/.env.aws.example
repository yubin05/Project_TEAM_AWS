APP_MODE=aws
PORT=3003

# RDS MySQL 엔드포인트
DB_HOST=your-rds-endpoint.ap-northeast-2.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=your-rds-password
DB_NAME=booking_db

# JWT / 내부 통신 시크릿
JWT_SECRET=your-jwt-secret
INTERNAL_SECRET=your-internal-secret

# CORS: Amplify 앱 도메인으로 제한
CORS_ORIGIN=https://your-app.amplifyapp.com

# 서비스 간 내부 통신
HOTEL_SERVICE_URL=http://hotel-service:3002

AWS_REGION=ap-northeast-2
