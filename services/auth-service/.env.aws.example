APP_MODE=aws
PORT=3001

# RDS MySQL 엔드포인트
DB_HOST=your-rds-endpoint.ap-northeast-2.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=your-rds-password
DB_NAME=auth_db

# JWT / 내부 통신 시크릿 (Secrets Manager 또는 직접 입력)
JWT_SECRET=your-jwt-secret
INTERNAL_SECRET=your-internal-secret

# CORS: Amplify 앱 도메인으로 제한
CORS_ORIGIN=https://your-app.amplifyapp.com

AWS_REGION=ap-northeast-2
